# you shouldn't commit these into source control
# these are the default directory names, adjust/add to fit your needs
target/
dbt_packages/
logs/

# Dashboard secrets and virtual environment
dashboard/.streamlit/secrets.toml
dashboard/venv/
.streamlit/secrets.toml

# Local QA reports / spreadsheets
*.xlsx
.~lock.*#

# Claude Code local state (settings.local.json, scheduled_tasks.lock, etc.)
# Use a file glob rather than a directory so git still descends into .claude/
# and honours the negation for shared skills.
.claude/*
!.claude/skills/

# Python bytecode
__pycache__/
*.pyc
